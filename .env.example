# ============================================
# Offer-Mate 服务器环境变量配置模板
# ============================================
# 使用说明：复制此文件为 .env，然后填入实际值

# 应用环境配置
NODE_ENV=development
PORT=7002
API_PREFIX=/offer-mate/v1

# 数据库配置 (Offer-Mate 独立数据库)
DB_HOST=localhost
DB_PORT=3306
DB_USER=offermate
DB_PASSWORD=offermate123@
DB_NAME=offer_mate

# JWT认证配置
JWT_SECRET=offer_mate_secret_key_change_in_production_12345
JWT_EXPIRES_IN=7d

# 阿里云短信配置 (可选)
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SIGN_NAME=
ALIYUN_TEMPLATE_CODE=

# 服务器日志配置
LOG_LEVEL=info
